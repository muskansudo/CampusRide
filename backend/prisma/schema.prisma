generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  driverProfile    DriverProfile?
  passengerRides   Ride[]         @relation("PassengerRides")
  driverRides      Ride[]         @relation("DriverRides")
  ratingsGiven     Rating[]         @relation("RatingsGiven")
  ratingsReceived  Rating[]         @relation("RatingsReceived")
  rideRejections   RideRejection[]

  @@map("users")
}

model DriverProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique @map("user_id")
  vehicleType        String             @map("vehicle_type")
  vehicleNumber      String             @map("vehicle_number")
  licenseNumber              String?            @map("license_number")
  governmentIdNumber         String?            @map("government_id_number")
  verificationRejectionReason String?           @map("verification_rejection_reason")
  verificationSubmittedAt    DateTime?          @map("verification_submitted_at")
  verificationStatus         VerificationStatus @default(PENDING) @map("verification_status")
  isOnline           Boolean            @default(false) @map("is_online")
  currentLat         Float?             @map("current_lat")
  currentLng         Float?             @map("current_lng")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_profiles")
}

model Ride {
  id                  String     @id @default(cuid())
  passengerId         String     @map("passenger_id")
  driverId            String?    @map("driver_id")
  pickupLocation      String     @map("pickup_location")
  destinationLocation String     @map("destination_location")
  pickupLat           Float?     @map("pickup_lat")
  pickupLng           Float?     @map("pickup_lng")
  destLat             Float?     @map("dest_lat")
  destLng             Float?     @map("dest_lng")
  status              RideStatus @default(REQUESTED)
  cancelReason        String?    @map("cancel_reason")
  cancelledBy         String?    @map("cancelled_by")
  scheduledAt         DateTime?  @map("scheduled_at")
  driversNotifiedAt   DateTime?  @map("drivers_notified_at")
  requestedAt         DateTime   @default(now()) @map("requested_at")
  acceptedAt          DateTime?  @map("accepted_at")
  startedAt           DateTime?  @map("started_at")
  completedAt         DateTime?  @map("completed_at")
  cancelledAt         DateTime?  @map("cancelled_at")

  passenger  User            @relation("PassengerRides", fields: [passengerId], references: [id])
  driver     User?           @relation("DriverRides", fields: [driverId], references: [id])
  rating     Rating?
  rejections RideRejection[]

  @@index([status, requestedAt])
  @@index([status, scheduledAt])
  @@index([driverId, status])
  @@index([passengerId, status])
  @@map("rides")
}

model Rating {
  id          String   @id @default(cuid())
  rideId      String   @unique @map("ride_id")
  passengerId String   @map("passenger_id")
  driverId    String   @map("driver_id")
  rating      Int
  feedback    String?
  createdAt   DateTime @default(now()) @map("created_at")

  ride      Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  passenger User @relation("RatingsGiven", fields: [passengerId], references: [id])
  driver    User @relation("RatingsReceived", fields: [driverId], references: [id])

  @@map("ratings")
}

model RideRejection {
  id         String   @id @default(cuid())
  rideId     String   @map("ride_id")
  driverId   String   @map("driver_id")
  rejectedAt DateTime @default(now()) @map("rejected_at")

  ride   Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([rideId, driverId])
  @@map("ride_rejections")
}
